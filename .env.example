# =====================================================================
# IOT-Modular-Microservice — Secrets Only
# Copy ke .env dan isi dengan nilai sebenarnya.
# JANGAN commit file .env ke git.
# =====================================================================

# ─── Shared Database Credentials ───────────────────────────────────────
DB_USER=app
DB_PASSWORD=app1234
MYSQL_ROOT_PASSWORD=app1234

# ─── JWT (Auth Service) ───────────────────────────────────────────────
JWT_SECRET=changeme-use-a-very-long-random-string-here

# ─── Default Admin ────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@smartfarm.local
ADMIN_PASSWORD=admin1234

# ─── Kong JWT Secrets ─────────────────────────────────────────────────
KONG_JWT_SECRET_FRONTEND=changeme-frontend-secret

# ─── NATS per-service passwords ───────────────────────────────────────
MODULE_NATS_PASSWORD=moduleNatsPass!
ALERT_NATS_PASSWORD=alertNatsPass!
CONTROL_NATS_PASSWORD=controlNatsPass!
AUTH_NATS_PASSWORD=authNatsPass!
ANALYTICS_NATS_PASSWORD=analyticsNatsPass!
NOTIFICATION_NATS_PASSWORD=notifNatsPass!
AUDIT_NATS_PASSWORD=auditNatsPass!
WS_NATS_PASSWORD=wsNatsPass!

# ─── MQTT (Mosquitto internal broker) ─────────────────────────────────
# Broker internal (container mosquitto): tcp://mosquitto:1883
MQTT_URL=tcp://mosquitto:1883
MQTT_USER=smartfarm-svc
MQTT_PASS=SmartFarmPass123

# MQTT topic prefix — HARUS sama dengan firmware (Config::MQTT_TOPIC_PREFIX)
MQTT_TOPIC_PREFIX=smartfarm

# ─── MinIO ────────────────────────────────────────────────────────────
# Root credential (keep for admin/bootstrap only; services use scoped keys below).
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Scoped access keys per service (O2 remediation).
MINIO_STREAM_ACCESS_KEY=stream-svc
MINIO_STREAM_SECRET_KEY=29B1XkbNURJVDKLourhEQlked9Qdl9Rmoo5r5B62
MINIO_ML_ACCESS_KEY=fXaqHEsNJOFfQQCkE5Sc
MINIO_ML_SECRET_KEY=zpHJI7J0ojPoao1Kc2ZSpKzcpHI3zdn5e7bXBBRv

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ─── SMTP (Email delivery for Notification / Webhook services) ────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=email.sistem.anda@gmail.com
SMTP_PASS=16_digit_app_password
SMTP_FROM=alert@smartfarm.local
ALERT_RECEIVER_EMAIL=admin.it@perusahaan.com

# ─── Telegram Bot ─────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=-1001234567890

# ─── Webhook Service ──────────────────────────────────────────────────
WEBHOOK_SECRET=changeme-webhook-secret

# ─── Cloudflare Tunnel ────────────────────────────────────────────────
CLOUDFLARED_TUNNEL_TOKEN=

# ─── Grafana ──────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change-me-strong-password
GRAFANA_DOMAIN=grafana.smartfarm.example
GRAFANA_PUBLIC_URL=https://grafana.smartfarm.example

# ─── Dashboard / Frontend ────────────────────────────────────────────
VITE_API_URL=https://api.smartfarm.example
