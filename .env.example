# =====================================================================
# IOT-Modular-Microservice — Environment Variables
# Copy ke .env dan sesuaikan nilainya
# JANGAN commit file .env ke git
# =====================================================================

# ─── Shared Database Credentials ───────────────────────────────────────
# SATU user & SATU password dipakai bersama oleh SELURUH instance database
# (MariaDB auth/control/module + TimescaleDB module/analytics) serta exporter.
# Database NAME masing-masing tetap berbeda (lihat di bawah).
DB_USER=app
DB_PASSWORD=app1234

# Root superuser (wajib untuk image MariaDB; tidak dipakai oleh aplikasi)
MYSQL_ROOT_PASSWORD=app1234

# ─── MariaDB Auth ─────────────────────────────────────────────────────
MYSQL_DATABASE_AUTH=auth_db

# ─── Module Service (MariaDB + TimescaleDB + Redis) ───────────────────
MYSQL_DATABASE_MODULE=module_db
TIMESCALE_DATABASE_MODULE=module_ts

# ─── Analytics Service (TimescaleDB only) ────────────────────────────
TIMESCALE_ANALYTICS_DB=analytics_ts

# ─── Control Service (MariaDB only) ──────────────────────────────────
MYSQL_DATABASE_CONTROL=control_db
# Detik menunggu ACK /confirm dari firmware sebelum command ditandai timeout
ACK_TIMEOUT_SECONDS=8

# ─── Stream Service (MariaDB + MediaMTX) ─────────────────────────────
MYSQL_DATABASE_STREAM=stream_db
CCTV_RTSP_URL=rtsp://admin:Admin_TF24!@192.169.1.110:554/Streaming/Channels/101
CCTV_CAPTURE_INTERVAL_HOURS=8
CCTV_CAPTURE_CRON=
CCTV_CAPTURE_STREAMS=
KONG_PUBLIC_URL=http://localhost:8000

# ─── ML / Vision API (MariaDB + YOLO) ────────────────────────────────
MYSQL_DATABASE_ML=ml_db

# ─── Audit Service (MariaDB append-only log) ─────────────────────────
MYSQL_DATABASE_AUDIT=audit_db

# ─── Alert Service (MariaDB thresholds + alert history) ───────────────
MYSQL_DATABASE_ALERT=alert_db

# ─── Notification Service (MariaDB settings + log history) ────────────
MYSQL_DATABASE_NOTIFICATION=notification_db

# ─── Consolidated Exporters (ADR-005) ─────────────────────────────
# Single multi-process container per DB type. Each target DB gets one
# exporter process on a fixed port (set via *_DSN_<n> below).
# Port mapping (must match infra/prometheus/prometheus.yml):
#   mysqld-exporter-all : 9104 auth, 9105 control, 9106 module, 9107 stream,
#                         9108 audit, 9109 alert, 9110 notification, 9111 ml
#   postgres-exporter-all: 9187 timescaledb-module, 9188 timescaledb-analytics
# Credentials reuse the shared DB_USER/DB_PASSWORD above.
MYSQL_DSN_AUTH="${DB_USER}:${DB_PASSWORD}@(mariadb-auth:3306)/"
MYSQL_DSN_CONTROL="${DB_USER}:${DB_PASSWORD}@(mariadb-control:3306)/"
MYSQL_DSN_MODULE="${DB_USER}:${DB_PASSWORD}@(mariadb-module:3306)/"
MYSQL_DSN_STREAM="${DB_USER}:${DB_PASSWORD}@(mariadb-stream:3306)/"
MYSQL_DSN_AUDIT="${DB_USER}:${DB_PASSWORD}@(mariadb-audit:3306)/"
MYSQL_DSN_ALERT="${DB_USER}:${DB_PASSWORD}@(mariadb-alert:3306)/"
MYSQL_DSN_NOTIFICATION="${DB_USER}:${DB_PASSWORD}@(mariadb-notification:3306)/"
MYSQL_DSN_ML="${DB_USER}:${DB_PASSWORD}@(mariadb-ml:3306)/"

POSTGRES_DSN_MODULE="postgresql://${DB_USER}:${DB_PASSWORD}@timescaledb-module:5432/${TIMESCALE_DATABASE_MODULE}?sslmode=disable"
POSTGRES_DSN_ANALYTICS="postgresql://${DB_USER}:${DB_PASSWORD}@timescaledb-analytics:5432/${TIMESCALE_ANALYTICS_DB}?sslmode=disable"

# ─── Redis (shared instance, multi-DB) ────────────────────────────
# SATU instance Redis bersama untuk seluruh service (konsolidasi ADR-004,
# pola sama seperti MinIO). Isolation via logical DB, bukan container terpisah.
# Module=DB0, Alert=DB1, Notification=DB2, Export=DB3 (cctv-capture pakai DB0).
# Redis hanya cache/ephemeral — prinsip Database-per-Service (MariaDB/Timescale)
# tetap terjaga karena masing-masing service punya database relasional sendiri.
REDIS_SHARED_ADDR=redis-shared:6379
REDIS_MODULE_DB=0
REDIS_ALERT_DB=1
REDIS_NOTIFICATION_DB=2
REDIS_EXPORT_DB=3

# ─── MinIO (shared object storage: stream/ml/ota buckets) ────────────
# Stream Service Fase 5 BELUM memakai MinIO; diprovisi untuk Fase 6/10.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_STREAM_BUCKET=stream
MINIO_RESULT_BUCKET=ml-result
MINIO_ML_BUCKET=ml
MINIO_OTA_BUCKET=ota

# MQTT topic prefix — HARUS sama dengan firmware (Config::MQTT_TOPIC_PREFIX)
MQTT_TOPIC_PREFIX=smartfarm

# MQTT broker endpoint untuk Module Service.
# - Pakai broker internal (container mosquitto):  tcp://mosquitto:1883
# - Pakai broker eksternal (mis. di LAN):         tcp://192.168.1.103:1884
MQTT_URL=tcp://192.168.1.103:1884
MQTT_USER=
MQTT_PASS=

# ─── JWT (Auth Service) ───────────────────────────────────────────────
# Gunakan string panjang acak minimal 32 karakter
JWT_SECRET=changeme-use-a-very-long-random-string-here
JWT_EXPIRY=12h
REFRESH_EXPIRY=168h

# ─── Default Admin (seeded on first startup) ──────────────────────────
# Ganti password ini setelah login pertama.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@smartfarm.local
ADMIN_PASSWORD=admin1234

# ─── Kong JWT Secrets ─────────────────────────────────────────────────
KONG_JWT_SECRET_FRONTEND=changeme-frontend-secret
KONG_JWT_SECRET_ESP32=changeme-esp32-secret

# ─── CORS (Frontend URL) ──────────────────────────────────────────────
# Harus = hostname publik dashboard (origin browser) agar Kong CORS
# mengizinkan panggilan API dari dashboard via Cloudflare Tunnel.
FRONTEND_URL=https://app.smartfarm.example

# ─── NATS per-service passwords ───────────────────────────────────────
MODULE_NATS_PASSWORD=moduleNatsPass!
ALERT_NATS_PASSWORD=alertNatsPass!
CONTROL_NATS_PASSWORD=controlNatsPass!
AUTH_NATS_PASSWORD=authNatsPass!
ANALYTICS_NATS_PASSWORD=analyticsNatsPass!
NOTIFICATION_NATS_PASSWORD=notifNatsPass!
AUDIT_NATS_PASSWORD=auditNatsPass!
WS_NATS_PASSWORD=wsNatsPass!

# ─── Grafana (Service Health Dashboard) ────────────────────────────────
# Set a STRONG password before deploying. Grafana is bound to localhost only
# in docker-compose; do not expose it publicly with these example values.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-strong-password

# ─── Public URLs (via Cloudflare Tunnel) ────────────────────────────
# Isi dengan hostname publik yang sudah kamu daftarkan di Cloudflare
# Zero Trust dashboard (Access → Tunnels → public hostname).
# Contoh: https://api.smartfarm.example
VITE_API_URL=https://api.smartfarm.example
GRAFANA_PUBLIC_URL=https://grafana.smartfarm.example
GRAFANA_DOMAIN=grafana.smartfarm.example

# ─── Cloudflare Tunnel (cloudflared → Kong) ─────────────────────────
# Token dari `docker compose run --rm cloudflared tunnel token <nama>`.
# Token berisi kredensial tunnel — JANGAN commit ke git.
CLOUDFLARED_TUNNEL_TOKEN=
# Hostname publik yang dipetakan ke Kong:8000 (sudah di-pointing ke tunnel
# di dashboard Cloudflare DNS), mis. api.smartfarm.example
CLOUDFLARED_HOSTNAME=
