{
  "version": 1,
  "author": "SmartFarm Project",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-esp32-devkit-v1",
      "id": "esp",
      "top": 0,
      "left": 0,
      "attrs": {}
    },
    {
      "type": "wokwi-led",
      "id": "led",
      "top": 50,
      "left": -100,
      "attrs": { "color": "green" }
    },
    {
      "type": "wokwi-resistor",
      "id": "res",
      "top": 100,
      "left": -80,
      "attrs": { "value": "220" }
    }
  ],
  "connections": [
    [ "esp:TX0", "$serialMonitor:RX", "", [] ],
    [ "esp:RX0", "$serialMonitor:TX", "", [] ],
    
    [ "led:C", "esp:GND.2", "black", [ "v0" ] ],
    [ "led:A", "res:2", "green", [ "v0" ] ],
    [ "res:1", "esp:D2", "green", [ "v0" ] ]
  ]
